{
  "name": "zhihui-reading",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "desktop:build": "vite build && electron-builder --win dir --x64 --publish never"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "electron": "^37.2.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "pptxgenjs": "^4.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.4"
  },
  "build": {
    "appId": "com.zhihui.reading",
    "productName": "智绘阅读",
    "directories": {
      "output": "install",
      "buildResources": "public"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraFiles": [
      {
        "from": "pic_db",
        "to": "pic_db",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".",
        "to": ".",
        "filter": [
          "*.txt"
        ]
      },
      {
        "from": ".",
        "to": ".",
        "filter": [
          "app_state_snapshot.json"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
